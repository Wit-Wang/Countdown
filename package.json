{
  "name": "countdown",
  "private": true,
  "version": "1.0.0",
  "license": "CC-BY-NC-SA-4.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint --ext .ts,.tsx,.vue --format unix src",
    "lint:fix": "eslint --ext .ts,.tsx,.vue --format unix src --fix",
    "lint:json": "eslint --ext .ts,.tsx,.vue --format json --output-file eslint-report.json src",
    "format": "prettier --write \"src/**/*.{js,ts,vue,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,ts,vue,json,md}\""
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-formatter-unix": "^9.0.1",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.9.0",
    "prettier": "^3.8.3",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^2.1.10",
    "vitest": "^4.1.5"
  }
}
